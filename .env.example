APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
PUBLIC_BASE_URL=https://vpn.example.com
INTERNAL_API_TOKEN=change-me
ARTIFACTS_DIR=artifacts

DATABASE_URL=postgresql+asyncpg://vpn:vpn@127.0.0.1:5432/vpn

TELEGRAM_BOT_TOKEN=change-me
TELEGRAM_WEBHOOK_SECRET=change-me

YOOKASSA_SHOP_ID=change-me
YOOKASSA_SECRET_KEY=change-me
YOOKASSA_WEBHOOK_SECRET=change-me
YOOKASSA_RETURN_URL=https://vpn.example.com/payments/return

VPN_SSH_USERNAME=vpnrunner
VPN_SSH_PRIVATE_KEY_PATH=/opt/vpn/.ssh/id_ed25519
VPN_SSH_PORT=22
VPN_REMOTE_SCRIPTS_DIR=/usr/local/bin

DEFAULT_COUNTRY_CODE=nl
