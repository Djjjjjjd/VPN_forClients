[Unit]
Description=VPN platform backend
After=network.target

[Service]
Type=simple
User=vpn
WorkingDirectory=/opt/vpn/VPN_forClients
EnvironmentFile=/opt/vpn/VPN_forClients/.env
ExecStart=/opt/vpn/.venv/bin/uvicorn backend_app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
